<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">

    <title>Заявки</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<div class="container mt-5">

    <div class="d-flex justify-content-between mb-4">

        <h2>Заявки с формы</h2>

        <a
            href="/logout"
            class="btn btn-danger"
        >
            Выйти
        </a>

    </div>

    <form
        class="row mb-4"
        method="GET"
        action="/appointments"
    >

        <div class="col-md-5">
            <input
                type="text"
                name="search"
                value="<%= search %>"
                class="form-control"
                placeholder="Поиск по ФИО"
            >
        </div>

        <div class="col-md-3">

            <select
                name="sort"
                class="form-select"
            >
                <option value="desc">
                    Сначала новые
                </option>

                <option value="asc">
                    Сначала старые
                </option>

            </select>

        </div>

        <div class="col-md-2">

            <button
                class="btn btn-primary w-100"
            >
                Найти
            </button>

        </div>

    </form>

    <table class="table table-bordered">

        <thead>

        <tr>
            <th>Дата</th>
            <th>ФИО</th>
            <th>Телефон</th>
            <th>Проблема</th>
        </tr>

        </thead>

        <tbody>

        <% appointments.forEach(item => { %>

            <tr>

                <td>
                    <%= new Date(item.createdAt)
                        .toLocaleString("ru-RU") %>
                </td>

                <td>
                    <%= item.fullName %>
                </td>

                <td>
                    <%= item.phone %>
                </td>

                <td>
                    <%= item.problem %>
                </td>

            </tr>

        <% }) %>

        </tbody>

    </table>

    <nav>

        <ul class="pagination">

            <% for(let i = 1; i <= totalPages; i++){ %>

                <li
                    class="page-item <%= page === i ? 'active' : '' %>"
                >

                    <a
                        class="page-link"
                        href="/appointments?page=<%= i %>&search=<%= search %>"
                    >
                        <%= i %>
                    </a>

                </li>

            <% } %>

        </ul>

    </nav>

</div>

</body>
</html>